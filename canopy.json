{
    "type": "package",
    "name": "canopy/virtual-list",
    "summary": "Headless virtual scrolling for large lists, horizontal lists, and grids",
    "license": "BSD-3-Clause",
    "version": "1.0.0",
    "exposed-modules": [
        "VirtualList",
        "VirtualList.Horizontal",
        "VirtualList.Grid",
        "VirtualList.Scroll",
        "VirtualList.Measurement",
        "VirtualList.InfiniteScroll",
        "VirtualList.StickyHeader"
    ],
    "canopy-version": "0.19.0 <= v < 0.20.0",
    "dependencies": {
        "canopy/core": "1.0.0 <= v < 2.0.0",
        "canopy/html": "1.0.0 <= v < 2.0.0",
        "canopy/json": "1.0.0 <= v < 2.0.0",
        "canopy/browser": "1.0.0 <= v < 2.0.0"
    },
    "test-dependencies": {
        "canopy/test": "1.0.0 <= v < 3.0.0"
    }
}
